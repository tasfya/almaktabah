<%#
  Locals:
    hits: Array<TypesenseSearch::SearchHit>
%>
<% return if hits.blank? %>
<section class="mb-8">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-lg md:text-xl font-semibold flex items-center gap-2">
      <%= icon "sparkles", class: "w-5 h-5 text-primary" %>
      <%= t("home.sections.recent_feed") %>
    </h2>
  </div>
  <div class="bg-base-100 rounded-2xl border border-base-300 overflow-hidden">
    <% hits.each_with_index do |hit, index| %>
      <a href="<%= hit.url %>"
         class="group flex items-center gap-4 p-4 hover:bg-base-200/60 transition-colors <%= 'border-t border-base-300' unless index.zero? %>"
         data-turbo-frame="_top">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-1.5 text-xs text-base-content/60 mb-1">
            <span class="text-primary">●</span>
            <%= home_type_label(hit) %>
          </div>
          <h3 class="font-bold text-base md:text-[17px] leading-snug line-clamp-2 group-hover:text-primary transition-colors">
            <%= hit.title %>
          </h3>
          <p class="text-sm text-base-content/60 mt-0.5 truncate">
            <% if hit.scholar_name.present? %><%= t("search.results.sheikh") %> <%= hit.scholar_name %><% end %>
            <% if hit.respond_to?(:duration) && hit.duration.to_i > 0 %> · <%= format_duration(hit.duration) %><% end %>
          </p>
        </div>
        <div class="w-20 h-20 rounded-xl overflow-hidden shrink-0 grid place-items-center" style="<%= home_gradient(hit) unless hit.thumbnail_url.present? %>">
          <% if hit.thumbnail_url.present? %>
            <%= image_tag hit.thumbnail_url, alt: hit.title, loading: "lazy", decoding: "async",
                          class: "w-full h-full object-cover" %>
          <% else %>
            <%= icon home_type_icon(hit), class: "w-7 h-7 text-white/80" %>
          <% end %>
        </div>
      </a>
    <% end %>
  </div>
</section>

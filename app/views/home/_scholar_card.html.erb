<%#
  Locals:
    scholar: Scholar
    count:   Integer (lecture count, for the chip)
%>
<%
  scholar_filter_path = lectures_path(scholars: scholar.full_name)
%>
<div class="card card-border bg-base-100 hover:bg-base-200 transition-colors shadow-sm hover:shadow-md text-center">
  <div class="card-body items-center p-4 gap-2">
    <div class="avatar avatar-placeholder">
      <div class="bg-primary/10 text-primary w-16 h-16 rounded-full flex items-center justify-center">
        <%= icon "user", class: "w-8 h-8" %>
      </div>
    </div>
    <h3 class="font-semibold text-sm md:text-base line-clamp-2">
      <%= link_to scholar.full_name, scholar_filter_path,
                  class: "hover:text-primary stretched-link",
                  data: { turbo_frame: "_top" } %>
    </h3>
    <% if count.to_i > 0 %>
      <span class="badge badge-outline badge-sm">
        <%= t("home.scholar.lectures_count", count: count) %>
      </span>
    <% end %>
  </div>
</div>

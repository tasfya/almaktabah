<%#
  Locals:
    scholars: Array<Hash> with keys :scholar (Scholar) and :count (Integer)
%>
<% return if scholars.blank? || scholars.size < 3 %>
<section class="mt-10">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-lg md:text-xl font-semibold flex items-center gap-2">
      <%= icon "user-group", class: "w-5 h-5 text-primary" %>
      <%= t("home.sections.spotlight_scholars") %>
    </h2>
  </div>
  <div class="grid gap-4 grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-4 xl:grid-cols-6">
    <% scholars.each do |entry| %>
      <%= render "home/scholar_card", scholar: entry[:scholar], count: entry[:count] %>
    <% end %>
  </div>
</section>

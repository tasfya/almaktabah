<%#
  Locals:
    hit: TypesenseSearch::SearchHit (or nil)
%>
<% return if hit.blank? %>
<a href="<%= hit.url %>" class="block group mb-6" data-turbo-frame="_top">
  <div class="relative rounded-2xl overflow-hidden aspect-[16/8]" style="<%= home_gradient(hit) unless hit.thumbnail_url.present? %>">
    <% if hit.thumbnail_url.present? %>
      <%= image_tag hit.thumbnail_url,
                    alt: hit.title,
                    loading: "eager", fetchpriority: "high", decoding: "async",
                    class: "absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]" %>
    <% else %>
      <div class="absolute inset-0 grid place-items-center text-white/30">
        <%= icon home_type_icon(hit), class: "w-24 h-24" %>
      </div>
    <% end %>
    <span class="absolute top-3 right-3 text-xs text-primary-content px-2.5 py-1 rounded-full bg-primary">
      <%= t("home.sections.featured") %>
    </span>
    <div class="absolute inset-x-0 bottom-0 p-5 bg-gradient-to-t from-black/75 to-transparent">
      <h2 class="text-white text-xl md:text-2xl font-bold leading-snug line-clamp-2">
        <%= hit.title %>
      </h2>
      <p class="text-white/80 text-sm mt-1">
        <%= home_type_label(hit) %>
        <% if hit.scholar_name.present? %> · <%= t("search.results.sheikh") %> <%= hit.scholar_name %><% end %>
      </p>
    </div>
  </div>
</a>
